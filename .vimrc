" Enable line numbers
set number

" Enable relative line numbers
set relativenumber

" Use spaces instead of tabs
set expandtab
set tabstop=4
set shiftwidth=4
set autoindent

" Enable syntax highlighting
syntax on

" Set leader key to comma
let mapleader = ","

" Custom key mapping: bind <leader>a to ggVG (select all)
nnoremap <leader>a ggVG
